# =============================================================================
# Vivora — Environment Variables Example
# Copy this file to .env and fill in your values
# =============================================================================

# --- App ---
APP_ENV=development

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vivora
POSTGRES_USER=vivora
POSTGRES_PASSWORD=vivora_dev_password
DATABASE_URL=postgresql+asyncpg://vivora:vivora_dev_password@postgres:5432/vivora

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Google AI (Gemini chat + Veo video + Google TTS) ---
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-studio-key

# --- Google TTS voice settings (optional) ---
GOOGLE_TTS_VOICE_NAME=en-US-Wavenet-D
GOOGLE_TTS_LANGUAGE_CODE=en-US

# --- Gemini model (optional) ---
GEMINI_MODEL=gemini-2.0-flash

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
